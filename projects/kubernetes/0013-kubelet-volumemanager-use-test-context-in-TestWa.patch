From 868693712097ad9bbbaa097b75acbca7b4c90ea9 Mon Sep 17 00:00:00 2001
From: Davanum Srinivas <davanum@gmail.com>
Date: Mon, 16 Mar 2026 16:12:36 -0400
Subject: [PATCH] kubelet/volumemanager: use test context in
 TestWaitForAllPodsUnmount

The repeated concurrent WaitForAttachAndMount subtest in TestWaitForAllPodsUnmount launches 20 goroutines with context.Background(). Each goroutine then relies on the internal podAttachAndMountTimeout, which is short enough for the reconciler to time out under CI contention before all pods complete attach and mount.

The test already has a parent test context with the right lifetime for the setup phase. Use that context for the concurrent WaitForAttachAndMount calls so the setup does not fail early on the helper's internal timeout before the test reaches the intended WaitForAllPodsUnmount timeout path.

This matches the open upstream flake in kubernetes/kubernetes issue 136255 and the proposed upstream fix in PR 136790.

Tested:

- /opt/homebrew/bin/bash hack/verify-gofmt.sh

- /opt/homebrew/bin/bash hack/verify-typecheck.sh ./pkg/kubelet/volumemanager/...

- go test ./pkg/kubelet/volumemanager -run 'TestWaitForAllPodsUnmount$' -count=1

- /Users/dsrinivas/go/bin/stress -p 4 -count 12 -timeout 5m go test ./pkg/kubelet/volumemanager -run 'TestWaitForAllPodsUnmount$' -count=1
---
 pkg/kubelet/volumemanager/volume_manager_test.go | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/pkg/kubelet/volumemanager/volume_manager_test.go b/pkg/kubelet/volumemanager/volume_manager_test.go
index 64852206975..b0345ed1d66 100644
--- a/pkg/kubelet/volumemanager/volume_manager_test.go
+++ b/pkg/kubelet/volumemanager/volume_manager_test.go
@@ -741,7 +741,7 @@ func TestWaitForAllPodsUnmount(t *testing.T) {
 
 				for _, pod := range pods {
 					go func() {
-						err := manager.WaitForAttachAndMount(context.Background(), pod)
+						err := manager.WaitForAttachAndMount(ctx, pod)
 						resultChan <- attachResult{
 							podName: pod.Name,
 							err:     err,
-- 
