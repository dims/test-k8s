From 77a99cfd157796354c656a4d5db1309a73abcd8c Mon Sep 17 00:00:00 2001
From: Davanum Srinivas <davanum@gmail.com>
Date: Sun, 15 Mar 2026 23:26:28 -0400
Subject: [PATCH] test/integration/apiserver/discovery: give convergence more
 time

The local discovery stabilization patch already increased the shared polling budget in test/integration/apiserver/discovery, but the NVIDIA self-hosted integration lane is still timing out while waiting for v2 group versions to disappear in TestCRD/CRDAPIServiceSameGroupDifferentVersions.

Increase the shared discovery timeout again so cleanup, APIService removal, CRD removal, and v1/v2 discovery convergence have more headroom on slower CI runners. This is the same slow-convergence family as the earlier TestCRD/Race cleanup timeout.

Tested:

./hack/verify-gofmt.sh

./hack/verify-typecheck.sh ./test/integration/apiserver/discovery/...

go test ./test/integration/apiserver/discovery -run 'TestCRD/(Race|CRDAPIServiceSameGroupDifferentVersions)$' -count=3 -timeout 30m
---
 test/integration/apiserver/discovery/framework.go | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/test/integration/apiserver/discovery/framework.go b/test/integration/apiserver/discovery/framework.go
index bb335f885d7..3e8801d2e98 100644
--- a/test/integration/apiserver/discovery/framework.go
+++ b/test/integration/apiserver/discovery/framework.go
@@ -46,7 +46,9 @@ const acceptV1JSON = "application/json"
 const acceptV2JSON = "application/json;g=apidiscovery.k8s.io;v=v2;as=APIGroupDiscoveryList"
 const acceptV2JSONNoPeer = "application/json;g=apidiscovery.k8s.io;v=v2;as=APIGroupDiscoveryList;profile=nopeer"
 
-const maxTimeout = 30 * time.Second
+// Discovery integration tests frequently need to wait through aggregator,
+// API registration, and discovery document convergence on contended CI nodes.
+const maxTimeout = 120 * time.Second
 
 type testClient interface {
 	kubernetes.Interface
-- 
