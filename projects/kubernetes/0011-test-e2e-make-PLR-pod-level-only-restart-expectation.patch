+++ b/test/e2e/common/node/pod_level_resources_resize.go
@@ -41,6 +41,22 @@ import (
 	"github.com/onsi/ginkgo/v2"
 )
 
+// Pod-level limits can trigger a restart on some nodes even when the
+// container-specific resources stay unchanged. Treat those resize paths as
+// optional restarts until the kubelet behavior converges.
+func expectRestartForPolicy(policy v1.ResourceResizeRestartPolicy, containerChanged, podLevelLimitChanged bool) (int32, bool) {
+	if policy != v1.RestartContainer {
+		return 0, false
+	}
+	if containerChanged {
+		return 1, false
+	}
+	if podLevelLimitChanged {
+		return 0, true
+	}
+	return 0, false
+}
+
